MAX_LOSS = 0.01
PROFIT_THRESHOLD = 0.01


def calculate_change(current_price, predicted_price):
    return predicted_price - current_price


def calculate_expected_profit(current_price, predicted_price):

    change = calculate_change(current_price, predicted_price)

    # enforce maximum loss
    if change < -MAX_LOSS:
        return -MAX_LOSS

    return change


def generate_signal(current_price, predicted_price):

    change = calculate_change(current_price, predicted_price)

    if change >= PROFIT_THRESHOLD:
        return "BUY"

    if change <= -PROFIT_THRESHOLD:
        return "SELL"

    return "HOLD"


def maximize_profit(currency_predictions):

    """
    currency_predictions format

    {
        "EURUSD": (current_price, predicted_price),
        "GBPUSD": (current_price, predicted_price),
        "USDJPY": (current_price, predicted_price)
    }
    """

    best_pair = None
    best_profit = 0
    best_signal = "HOLD"

    for pair, prices in currency_predictions.items():

        current_price, predicted_price = prices

        expected_profit = calculate_expected_profit(
            current_price,
            predicted_price
        )

        # skip trades where loss exceeds limit
        if expected_profit < -MAX_LOSS:
            continue

        # find most profitable opportunity
        if expected_profit > best_profit:

            best_profit = expected_profit
            best_pair = pair
            best_signal = generate_signal(current_price, predicted_price)

    # if no profitable trade exists
    if best_pair is None or best_profit <= 0:

        return {
            "pair": None,
            "signal": "HOLD",
            "expected_profit": 0,
            "risk_limit": MAX_LOSS
        }

    return {
        "pair": best_pair,
        "signal": best_signal,
        "expected_profit": best_profit,
        "risk_limit": MAX_LOSS
    }